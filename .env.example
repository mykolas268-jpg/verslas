# ── Site ────────────────────────────────────────────────────────────────────
# Production origin used for canonical URLs, Open Graph tags, and sitemap.xml.
# Set this in your hosting provider (e.g. Vercel) to your real domain.
# Defaults to https://verslas.ai if unset.
NEXT_PUBLIC_SITE_URL=https://verslas.ai

# ── Admin panel (/admin) ─────────────────────────────────────────────────────
# Password you log in with at /admin.
ADMIN_PASSWORD=change-me-to-a-long-password
# Secret used to sign the admin session cookie (min 16 chars; use 32+ random).
# Generate one: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=replace-with-a-long-random-string

# ── Publishing target (production only) ──────────────────────────────────────
# When these are set, the admin commits posts to GitHub (which triggers a
# Vercel rebuild). When unset (e.g. local `npm run dev`), the admin writes the
# .mdx files to disk instead — handy for local authoring.
#
# Fine-grained Personal Access Token with Contents: Read & Write on the repo.
GITHUB_TOKEN=
# owner/repo, e.g. yourname/verslas-ai
GITHUB_REPO=
# Branch to commit to (defaults to main).
GITHUB_BRANCH=main
